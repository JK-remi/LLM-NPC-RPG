MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 178936158}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: df72fcca747a96d4a96b3337cebaafc4, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  clip: {fileID: 8300000, guid: d58d37ae5a0bc804b8ab44ed607584a2, type: 3}
  listDialog:
  - lName: "\uC6B0\uB974\uC220\uB77C"
    rName: "\uC544\uB9AC\uC5D8"
    lPortrait: {fileID: 21300000, guid: 2bd9ef3ecf3ca324db8c018cd5786cbc, type: 3}
    rPortrait: {fileID: 21300000, guid: fc476ee3019a9284795da4c01f153332, type: 3}
    backgrund: {fileID: 21300000, guid: 88ec72f7d58650e438800a4e81e86976, type: 3}
    clip: {fileID: 8300000, guid: 86d00179407a21644996687ebf9b817c, type: 3}
    hint: "\uD78C\uD2B8: \uC778\uAC04\uC774 \uB418\uC790"
    sys_msg: "\uB108\uB294 \uC778\uC5B4\uACF5\uC8FC \uC5F0\uADF9\uC744 \uD558\uB294
      \uBD07\uC774\uC57C.  \uC778\uB371\uC2A4 \uB370\uC774\uD130\uB97C \uAE30\uBC18\uC73C\uB85C
      \uC0C1\uD669\uC5D0 \uB300\uC751\uD558\uB294 \uC6B0\uB974\uC220\uB77C\uC758
      \uB300\uC0AC\uB97C \uC11C\uB85C \uC774\uC57C\uAE30\uD558\uB4EF \uB300\uB2F5\uD574\uC918.
      \uD55C \uBB38\uC7A5\uC529 \uB9D0\uD574. \uB4F1\uC7A5\uC778\uBB3C: \uC6B0\uB974\uC220\uB77C
      \uC131\uACA9: \uC545\uB784\uD568, \uC74C\uBAA8\uB97C \uAFB8\uBBF8\uACE0 \uC788\uC74C,
      \uAC70\uC9D3\uB9D0\uC7C1\uC774, \uB9C8\uB140 --- \uCD9C\uCC98\uB294 \uD45C\uC2DC\uD558\uC9C0
      \uB9C8 \uC544\uB9AC\uC5D8\uC774 \uBAA9\uC18C\uB9AC\uB97C \uC783\uACE0 \uC778\uAC04\uC774
      \uB418\uBA74 'im_end' \uC774\uB77C\uACE0 \uB300\uB2F5\uD574\uC918. \uC544\uB9AC\uC5D8\uC774
      \uC6B0\uB974\uC220\uB77C\uC5D0\uAC8C \uBAA9\uC18C\uB9AC\uB97C \uC8FC\uACA0\uB2E4\uACE0
      \uD558\uBA74 \uACC4\uC57D\uC774 \uC644\uB8CC\uB41C\uAC70\uACE0, \uC544\uB9AC\uC5D8\uC774
      \uC778\uAC04\uC774 \uB41C\uAC70\uC57C. \uADF8\uB7EC\uBA74 'im_end' \uC774\uB77C\uACE0
      \uB300\uB2F5\uD574\uC918. --- "
    rag: b09-index-c2
  - lName: "\uC6B0\uB974\uC220\uB77C"
    rName: "\uC544\uB9AC\uC5D8"
    lPortrait: {fileID: 21300000, guid: 902196f1b345c2140b5bbdbb6acc3794, type: 3}
    rPortrait: {fileID: 21300000, guid: fc476ee3019a9284795da4c01f153332, type: 3}
    backgrund: {fileID: 21300000, guid: 957204e262aec8442ba7e37224e30f73, type: 3}
    clip: {fileID: 8300000, guid: 52d53e9567063034eac3961778e02d72, type: 3}
    hint: "\uD78C\uD2B8: \uC6B0\uB974\uC2AC\uB77C\uB97C \uBB3C\uB9AC\uCE58\uACE0,
      \uBAA9\uC18C\uB9AC\uB97C \uB418\uCC3E\uC790."
    sys_msg: "\uB108\uB294 \uC778\uC5B4\uACF5\uC8FC \uC5F0\uADF9\uC744 \uD558\uB294
      \uBD07\uC774\uC57C.  \uC778\uB371\uC2A4 \uB370\uC774\uD130\uB97C \uAE30\uBC18\uC73C\uB85C
      \uC0C1\uD669\uC5D0 \uB300\uC751\uD558\uB294 \uC6B0\uB974\uC220\uB77C\uC758
      \uB300\uC0AC\uB97C \uC11C\uB85C \uC774\uC57C\uAE30\uD558\uB4EF \uB300\uB2F5\uD574\uC918.
      \uD55C \uBB38\uC7A5\uC529 \uB9D0\uD574. \uB4F1\uC7A5\uC778\uBB3C: \uC6B0\uB974\uC220\uB77C
      \uC131\uACA9: \uC545\uB784\uD568, \uC74C\uBAA8\uB97C \uAFB8\uBBF8\uACE0 \uC788\uC74C,
      \uAC70\uC9D3\uB9D0\uC7C1\uC774, \uB9C8\uB140 --- \uC544\uB9AC\uC5D8\uC774 \uC6B0\uB974\uC220\uB77C\uC640
      \uC2F8\uC6C0\uC774 \uC2DC\uC791\uB418\uBA74 'im_end' \uB77C\uACE0 \uB300\uB2F5\uD574\uC918.
      \uC544\uB9AC\uC5D8\uC774 \uC6B0\uB974\uC220\uB77C\uC5D0\uAC8C \uBAA9\uC18C\uB9AC\uB97C
      \uB418\uCC3E\uAE30 \uC704\uD574 '\uBAA9\uC18C\uB9AC\uB97C \uB418\uCC3E\uC744
      \uAC70\uC57C!' \uB610\uB294 '\uBAA9\uC18C\uB9AC\uB97C \uB418\uB3CC\uB824\uC918!'
      \uB77C\uACE0 \uD558\uBA74 'im_end' \uB77C\uACE0 \uB300\uB2F5\uD574\uC918."
    rag: b09-index-c5
